        <mxCell id="PZFtHVs2kvjMPvQxO2Eu-5" value="&lt;h1&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;クラスター検出に必要なパラメータ（Drone Appでも使用する？）&lt;/font&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; // dot detection param&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; float min_dot_area_ = 10.0;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; float max_dot_area_ = 350.0;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; cv::Scalar lower_green_ = cv::Scalar(35, 100, 100); // H: 35, S: 100, V: 100&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; cv::Scalar upper_green_ = cv::Scalar(85, 255, 255); // H: 85, S: 255, V: 255&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; // landmark detection param&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; double include_gain_ = 1.5;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; int include_min_dot_num_ = 1;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; int include_max_dot_num_ = 7;&amp;nbsp;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;strokeColor=default;fillColor=none;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="eVOCJrVsWdeTUgFKmBaz-1" vertex="1">
